@model Leave_Request_Form.Models.Employee

@{
    ViewData["Title"] = "Edit";
    Layout = "~/views/shared/_Layout.cshtml";

}

<h1>Edit</h1>

<h4>Employee</h4>
<hr />
<div class="row">
