@using Microsoft.AspNetCore.SignalR
@using Microsoft.IdentityModel.Tokens
@model EmployeeLeaveViewModel;
<button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#PendingRequestModal">
   Pending Request
</button>

<div class="modal fade" id="PendingRequestModal" tabindex="-1" role="dialog" aria-labelledby="exampleModalCenterTitle" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="exampleModalLongTitle">این مرخصی مورد تائید است ؟ </h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times; </span>
                </button>
            </div>
            <div class="form-group">
                
                <select asp-for="Employee.EmployeeID"
                        class="form-control"
                        asp-items="ViewBag.EmployeeID"
                        id="employeeSelect">
                </select>
            
            </div>
            
            <div class="modal-body">
                <div class="modal-body">
                    @foreach (var item in Model.LeaveRequests)
                    {
                        <h5>@item.Employee.Name @item.Employee.Family - @item.Description</h5>
                    }
                </div>

             
             


            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-danger" data-dismiss="modal">Rejected</button>
                <button type="button" class="btn btn-success">Approved </button>
            </div>
        </div>
    </div>
</div>